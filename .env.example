# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Frontend - Publicly safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase (Backend/Edge Functions - NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Telegram (Backend/Edge Functions - NEVER expose to frontend)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
